---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  jsonLd?: Record<string, any>;
}

const { title, description, canonical, image, type = 'website', publishedTime, jsonLd } = Astro.props;
const siteUrl = 'https://www.partenairecroissance.com';
const defaultImage = '/icons/icon-512x512.png';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-EWWHH4X69V"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-EWWHH4X69V');
  </script>
  
  <!-- Google Tag Manager -->
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-KMMM3954');</script>
  <!-- End Google Tag Manager -->
  
  <!-- Clarity -->
  <script type="text/javascript">
    (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", "x8f3m3uhno");
  </script>
  <!-- End Clarity -->
  
  <title>{title} | Partenaire Croissance</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical || `${siteUrl}${Astro.url.pathname}`} />
  
  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={image || `${siteUrl}${defaultImage}`} />
  <meta property="og:url" content={canonical || `${siteUrl}${Astro.url.pathname}`} />
  <meta property="og:type" content={type} />
  <meta property="og:site_name" content="Partenaire Croissance" />
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={image || `${siteUrl}${defaultImage}`} />
  
  <!-- JSON-LD -->
  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/icons/icon-192x192.png" />
  <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
  <link rel="llms.txt" type="text/plain" href="/llms.txt" title="LLMs.txt" />
  <link rel="alternate" type="application/rss+xml" title="Partenaire Croissance Blog" href="/rss.xml" />
  
  <!-- BreadcrumbList JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.partenairecroissance.com/" }
    ]
  }
  </script>
  
  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', system-ui, sans-serif; background: #0a0f1a; color: #e2e8f0; line-height: 1.6; }
    a { color: #3b82f6; text-decoration: none; }
    a:hover { text-decoration: underline; }
    img { max-width: 100%; height: auto; }
    .container { max-width: 1120px; margin: 0 auto; padding: 0 1.5rem; }
    .btn { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.5rem; border-radius: 0.5rem; font-weight: 600; font-size: 0.95rem; transition: all 0.2s; cursor: pointer; border: none; }
    .btn-primary { background: #3b82f6; color: #fff; }
    .btn-primary:hover { background: #2563eb; text-decoration: none; }
    .btn-outline { border: 1px solid #3b82f6; color: #3b82f6; background: transparent; }
    .btn-outline:hover { background: #3b82f6; color: #fff; text-decoration: none; }
    h1, h2, h3, h4 { line-height: 1.2; font-weight: 700; }
    h1 { font-size: 2.5rem; } h2 { font-size: 1.75rem; margin-top: 2rem; margin-bottom: 0.75rem; } h3 { font-size: 1.25rem; margin-top: 1.5rem; margin-bottom: 0.5rem; }
    p { margin-bottom: 1rem; color: #94a3b8; } ul, ol { margin-bottom: 1rem; padding-left: 1.5rem; color: #94a3b8; } li { margin-bottom: 0.5rem; }
    .card { background: #1a2332; border: 1px solid #2a3a4e; border-radius: 0.75rem; padding: 1.5rem; }
    .tag { display: inline-block; padding: 0.2rem 0.6rem; border-radius: 9999px; background: #1d4ed8; color: #fff; font-size: 0.75rem; font-weight: 600; }
    header { border-bottom: 1px solid #1e293b; padding: 1rem 0; position: sticky; top: 0; background: #0a0f1a; z-index: 100; }
    header .container { display: flex; align-items: center; justify-content: space-between; }
    header nav a { color: #94a3b8; font-size: 0.9rem; margin-left: 1.5rem; }
    header nav a:hover { color: #e2e8f0; text-decoration: none; }
    footer { border-top: 1px solid #1e293b; padding: 2rem 0; margin-top: 4rem; text-align: center; color: #64748b; font-size: 0.85rem; }
    .hero { padding: 4rem 0; text-align: center; }
    .hero h1 { margin-bottom: 1rem; } .hero p { font-size: 1.15rem; max-width: 650px; margin: 0 auto 2rem; }
    .hero .btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
    .blog-card { transition: border-color 0.2s; cursor: pointer; }
    .blog-card:hover { border-color: #3b82f6; }
    .prose { max-width: 750px; margin: 0 auto; padding: 2rem 0; }
    .prose h2 { border-bottom: 1px solid #1e293b; padding-bottom: 0.5rem; }
    .prose table { width: 100%; border-collapse: collapse; margin: 1rem 0; font-size: 0.9rem; }
    .prose th, .prose td { border: 1px solid #1e293b; padding: 0.5rem 0.75rem; text-align: left; }
    .prose th { background: #1a2332; color: #e2e8f0; font-weight: 600; }
    .prose td { color: #94a3b8; }
    .prose code { background: #1a2332; padding: 0.1rem 0.3rem; border-radius: 0.25rem; font-size: 0.85rem; }
    .prose pre { background: #1a2332; padding: 1rem; border-radius: 0.5rem; overflow-x: auto; margin: 1rem 0; }
    .prose pre code { background: none; padding: 0; }
    @media (max-width: 768px) { h1 { font-size: 1.75rem; } .hero { padding: 2rem 0; } }
  </style>
</head>
<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KMMM3954"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->
  <header>
    <div class="container">
      <a href="/" style="font-weight:700;font-size:1.1rem;color:#e2e8f0;text-decoration:none">Partenaire Croissance</a>
      <nav>
        <a href="/sdr/">Call Recovery</a>
        <a href="/tradequote/">TradeQuote Pro</a>
        <a href="/blog/">Guides</a>
      </nav>
    </div>
  </header>
  <main><slot /></main>
  <footer><div class="container"><p>&copy; {new Date().getFullYear()} Partenaire Croissance. All rights reserved.</p></div></footer>
</body>
</html>
