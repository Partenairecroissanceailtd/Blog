---
import BaseLayout from '../../layouts/BaseLayout.astro';

const postList = [
  {
    title: 'Best Framing Tool Belt for Contractors (2026)',
    description: 'Review and compare top-rated tool belts for framing carpenters: leather and nylon models from OX, DEWALT, and WELKINLAND.',
    publishedDate: '2026-06-18',
    slug: '/b2b/framing-tool-belt-guide',
  },
  {
    title: 'The Best 7-1/4" Circular Saws for Professional Framers (2026)',
    description: 'Professional 7-1/4 inch circular saw reviews for framers: Makita, DEWALT, Skil, and more. Ergonomic design, magnesium footplate, and brushless motors.',
    publishedDate: '2026-06-18',
    slug: '/b2b/circular-saw-for-framing-guide',
  },
];
---

<BaseLayout>
  <div className="container mx-auto p-4 pt-6 md:p-6 lg:p-12 xl:p-24" style="max-width: 800px">
    <h1 className="text-3xl text-center">Blog</h1>
    <hr className="mb-8" />
    <ul>
      {postList.map((post) => (
        <li key={post.slug} className="mb-4">
          <article>
            <h2 className="text-xl font-bold mb-2">
              <a
                href={post.slug}
                className="text-gray-900 dark:text-gray-100 hover:text-blue-600"
              >
                {post.title}
              </a>
            </h2>
            <p className="text-gray-600 dark:text-gray-300 mb-4">
              {post.description}
            </p>
            <p className="text-gray-600 dark:text-gray-300">
              Published on {post.publishedDate}
            </p>
          </article>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
