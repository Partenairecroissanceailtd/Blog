---
import BaseLayout from '../../layouts/BaseLayout.astro';

const postList = [
  {
    title: 'The Best Reciprocating Saws for Cutting Trees, Limbing and Storm Cleanup (2026)',
    description: 'Professional reciprocating saw reviews for tree limbing, storm cleanup, and pruning. Milwaukee, DEWALT, Bosch, and Ryobi saws tested on green wood cutting speed, stroke length, and battery runtime.',
    publishedDate: '2026-06-19',
    slug: '/b2b/reciprocating-saw-cutting-trees-guide',
  },
  {
    title: 'The Best Reciprocating Saws for Home Projects and Shop Use (2026)',
    description: 'Professional-grade reciprocating saw reviews for shop use, home renovations, and side jobs. DEWALT, Bosch, Milwaukee, Ryobi, and Craftsman saws rated for value, power, and versatility.',
    publishedDate: '2026-06-19',
    slug: '/b2b/reciprocating-saw-home-use-guide',
  },
  {
    title: 'The Best Miter Saws for Home Projects & Contractor Work (2026)',
    description: 'Compare the best 10-inch and 12-inch miter saws for home improvement projects and professional contractor use. DEWALT, SKIL, Metabo HPT, Makita, and more tested for accuracy, power, and value.',
    publishedDate: '2026-06-18',
    slug: '/b2b/miter-saw-home-projects-guide',
  },
  {
    title: 'The Best Reciprocating Saws for Cutting Tree Roots & Demolition (2026)',
    description: 'Professional reciprocating saw reviews for cutting tree roots, demolition, and heavy-duty jobsite work. DEWALT, Bosch, Festool, Craftsman, and Metabo HPT saws compared for power, stroke length, and durability.',
    publishedDate: '2026-06-18',
    slug: '/b2b/reciprocating-saw-tree-roots-guide',
  },
  {
    title: 'Best Framing Tool Belt for Contractors (2026)',
    description: 'Review and compare top-rated tool belts for framing carpenters: leather and nylon models from OX, DEWALT, and WELKINLAND.',
    publishedDate: '2026-06-18',
    slug: '/b2b/framing-tool-belt-guide',
  },
  {
    title: 'The Best 7-1/4-Inch Circular Saws for Professional Framers (2026)',
    description: 'Professional 7-1/4 inch circular saw reviews for framers: Makita, DEWALT, Skil, and more. Ergonomic design, magnesium footplate, and brushless motors.',
    publishedDate: '2026-06-18',
    slug: '/b2b/circular-saw-for-framing-guide',
  },
];
---

<BaseLayout>
  <div className="container mx-auto p-4 pt-6 md:p-6 lg:p-12 xl:p-24" style="max-width: 800px">
    <h1 className="text-3xl text-center">Blog</h1>
    <hr className="mb-8" />
    <ul>
      {postList.map((post) => (
        <li key={post.slug} className="mb-4">
          <article>
            <h2 className="text-xl font-bold mb-2">
              <a
                href={post.slug}
                className="text-gray-900 dark:text-gray-100 hover:text-blue-600"
              >
                {post.title}
              </a>
            </h2>
            <p className="text-gray-600 dark:text-gray-300 mb-4">
              {post.description}
            </p>
            <p className="text-gray-600 dark:text-gray-300">
              Published on {post.publishedDate}
            </p>
          </article>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
