---
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = [
  // B2B Contractor Gear Guides (June 17)
  { title: 'Complete Tool Box Buying Guide for Contractors & Tradespeople', path: '/blog/b2b/tool-box-buying-guide/', desc: 'Learn how to choose the right tool box for your contracting business. From truck boxes to modular storage, covering every format tradespeople need.', date: '2026-06-17', tag: 'Tool Storage' },
  { title: '10 Best Tool Boxes Compared — 2026 Guide for Contractors', path: '/blog/b2b/tool-box-comparison/', desc: 'Side-by-side comparison of the top tool boxes and storage systems for contractors. Ratings, features, and pro recommendations.', date: '2026-06-17', tag: 'Tool Storage' },
  { title: 'Best Budget Tool Boxes for Contractors', path: '/blog/b2b/tool-box-budget/', desc: 'Affordable tool storage that doesn\'t sacrifice quality. Budget-friendly picks for contractors starting out or expanding their kit.', date: '2026-06-17', tag: 'Tool Storage' },
  { title: 'Modular vs Chest vs Tool Tote: Which Storage System?', path: '/blog/b2b/tool-box-modular-vs-chest/', desc: 'Tool chests, modular stackables, and totes each have strengths. Match the system to your trade and daily workflow.', date: '2026-06-17', tag: 'Tool Storage' },
  { title: 'Tool Box Organization Guide for Maximum Efficiency', path: '/blog/b2b/tool-box-organization/', desc: 'How to organize your tool storage system to save time, prevent theft, and extend tool life on active job sites.', date: '2026-06-17', tag: 'Tool Storage' },
  { title: 'Complete Work Boot Buying Guide for Construction Trades', path: '/blog/b2b/work-boots-buying-guide/', desc: 'Steel toe vs composite vs soft toe — pick the right work boot for your trade. Safety certifications, waterproofing, and fit explained.', date: '2026-06-17', tag: 'Work Boots' },
  { title: '10 Best Work Boots for Construction Compared — 2026', path: '/blog/b2b/work-boots-comparison/', desc: 'Eight top-rated work boots compared by safety features, durability, comfort, and value. Trade-specific recommendations included.', date: '2026-06-17', tag: 'Work Boots' },
  { title: 'Best Budget Work Boots Under $100 — Tested for Trades', path: '/blog/b2b/work-boots-budget/', desc: 'You don\'t need to spend a fortune for job site safety. These budget work boots deliver protection without breaking the bank.', date: '2026-06-17', tag: 'Work Boots' },
  { title: 'Steel Toe vs Composite Toe vs Alloy: Which Is Safest?', path: '/blog/b2b/work-boots-steel-vs-composite/', desc: 'Every safety toe type has trade-offs. Learn which one matches your job site hazards, climate, and comfort needs.', date: '2026-06-17', tag: 'Work Boots' },
  { title: 'How to Make Your Work Boots Last 3x Longer', path: '/blog/b2b/work-boots-maintenance/', desc: 'Daily, weekly, and monthly maintenance routines that double the lifespan of your work boots. Plus when to repair vs replace.', date: '2026-06-17', tag: 'Work Boots' },
  { title: 'Laser Measure Buying Guide for Contractors', path: '/blog/b2b/laser-measure-buying-guide/', desc: 'Complete guide to choosing a laser measuring tool. Range, accuracy, red vs green laser, and top recommendations for every trade.', date: '2026-06-17', tag: 'Laser Measures' },
  { title: '10 Best Laser Measures Compared — 2026 Contractor Reviews', path: '/blog/b2b/laser-measure-comparison/', desc: 'Top laser distance measurers compared side by side. From budget picks to Bluetooth-enabled pro models.', date: '2026-06-17', tag: 'Laser Measures' },
  { title: 'Best Budget Laser Measuring Tools Under $80', path: '/blog/b2b/laser-measure-budget/', desc: 'Accurate laser measures don\'t have to cost a fortune. These budget picks deliver pro-level precision under $80.', date: '2026-06-17', tag: 'Laser Measures' },
  { title: 'Laser Measure vs Tape Measure: When to Use Each', path: '/blog/b2b/laser-measure-vs-tape/', desc: 'Both tools have their place on a job site. Learn when a laser saves time and when a tape is still the right call.', date: '2026-06-17', tag: 'Laser Measures' },
  { title: 'How to Get the Most Accurate Measurements with a Laser', path: '/blog/b2b/laser-measure-accuracy/', desc: 'Pro tips for ±1/16" accuracy every time. Surface conditions, environmental factors, and measurement techniques that matter.', date: '2026-06-17', tag: 'Laser Measures' },
  { title: 'Portable Power Station Buying Guide for Contractors', path: '/blog/b2b/portable-power-station-guide/', desc: 'How to choose a portable power station for your construction job site. Battery type, capacity, solar readiness, and real-world use cases.', date: '2026-06-17', tag: 'Power Stations' },
  { title: '8 Best Portable Power Stations Compared for Job Sites', path: '/blog/b2b/portable-power-station-comparison/', desc: 'Top power stations rated by output, runtime, durability, and value. Find the right capacity for your tools and crew.', date: '2026-06-17', tag: 'Power Stations' },
  { title: 'Best Budget Power Stations Under $500 for Contractors', path: '/blog/b2b/portable-power-station-budget/', desc: 'Silent, emission-free job site power without the premium price tag. These portable power stations deliver real value under $500.', date: '2026-06-17', tag: 'Power Stations' },
  { title: 'Power Station vs Gas Generator for Construction', path: '/blog/b2b/portable-power-station-vs-generator/', desc: 'Battery power stations vs traditional gas generators. Total cost of ownership, noise, maintenance, and when each makes sense.', date: '2026-06-17', tag: 'Power Stations' },
  { title: 'Solar-Ready Power Stations for Remote Job Sites', path: '/blog/b2b/portable-power-station-solar/', desc: 'Keep your crew powered off-grid with solar-compatible power stations. Panel sizing, charge times, and real contractor setups.', date: '2026-06-17', tag: 'Power Stations' },
  { title: 'Complete Job Site Lighting Guide for Contractors', path: '/blog/b2b/job-site-lighting-guide/', desc: 'Everything contractors need to know about job site lighting. Lumens, IP ratings, beam angles, power sources, and setup strategies.', date: '2026-06-17', tag: 'Job Site Lighting' },
  { title: '8 Best Job Site Lights Compared — Work Lights for Contractors', path: '/blog/b2b/job-site-lighting-comparison/', desc: 'Top-rated job site lights compared: tripod lights, string lights, battery-powered, and portable floodlights for every trade.', date: '2026-06-17', tag: 'Job Site Lighting' },
  { title: 'Best Budget Job Site Lights Under $100', path: '/blog/b2b/job-site-lighting-budget/', desc: 'Quality job site lighting doesn\'t have to cost a fortune. These budget work lights deliver reliable illumination under $100.', date: '2026-06-17', tag: 'Job Site Lighting' },
  { title: 'LED vs Halogen vs Battery Job Site Lights Compared', path: '/blog/b2b/job-site-lighting-led-vs-halogen/', desc: 'LED, halogen, and battery-powered lights each have strengths. Compare brightness, runtime, durability, and total cost by trade.', date: '2026-06-17', tag: 'Job Site Lighting' },
  { title: 'How Job Site Lighting Improves Construction Safety', path: '/blog/b2b/job-site-lighting-safety/', desc: 'OSHA requirements, accident prevention, fire hazards, and the ROI of proper lighting on active construction sites.', date: '2026-06-17', tag: 'Job Site Lighting' },
  { title: 'Shop Vac Buying Guide: Choosing the Right Wet/Dry Vacuum', path: '/blog/b2b/shop-vac-buying-guide/', desc: 'Complete guide to choosing a wet/dry vacuum for your trade business. Horsepower, tank size, filtration, and accessories covered.', date: '2026-06-17', tag: 'Shop Vacs' },
  { title: '8 Best Wet/Dry Shop Vacs Compared for Job Sites', path: '/blog/b2b/shop-vac-comparison/', desc: 'Top-rated shop vacs compared by suction power, capacity, durability, and value. Find the right vacuum for cleanup and dust control.', date: '2026-06-17', tag: 'Shop Vacs' },
  { title: 'Best Budget Shop Vacs That Don\'t Sacrifice Performance', path: '/blog/b2b/shop-vac-budget/', desc: 'Affordable wet/dry vacs that deliver pro-level suction. Budget picks for contractors who need reliable cleanup without overspending.', date: '2026-06-17', tag: 'Shop Vacs' },
  { title: 'What Size Shop Vac Do You Need? Tank Size Guide by Trade', path: '/blog/b2b/shop-vac-which-size/', desc: 'Tank size matters more than horsepower for most trades. Match your vac capacity to your trade, from 6-gallon to 16-gallon models.', date: '2026-06-17', tag: 'Shop Vacs' },
  { title: 'How to Maintain Your Shop Vac for Maximum Suction', path: '/blog/b2b/shop-vac-maintenance/', desc: 'Daily, weekly, and monthly maintenance routines that keep your wet/dry vac performing like new. Filter care, hose storage, and troubleshooting.', date: '2026-06-17', tag: 'Shop Vacs' },
  // New posts (June 17)
  { title: 'The Hidden Cost of Missed Calls on Google Ads for Tradies', path: '/blog/missed-calls-costing-ad-budget/', desc: 'Every missed call from Google Ads is $25–600 wasted. Learn how call recovery captures 100% of leads and books them into your calendar.', date: '2026-06-17', tag: 'Call Recovery' },
  { title: 'TradeQuote Pro: How Contractors Send Accurate Estimates in Minutes', path: '/blog/tradequote-pro-estimating-guide/', desc: 'Step-by-step guide to sending construction estimates with TradeQuote Pro. Custom templates, material pricing, and instant client delivery.', date: '2026-06-17', tag: 'TradeQuote Pro' },
  // Lead Gen / Ad articles for tradies
  { title: 'Facebook Ads for Home-Service Businesses: The 2026 Playbook', path: '/blog/facebook-ads-home-services/', desc: 'How HVAC, roofing, landscaping and contractors can use Meta ads — and why missed calls cost 72% of their leads.', date: '2026-06-16', tag: 'Meta Ads' },
  { title: 'Google Ads for Plumbers: How to Dominate Local Search in 2026', path: '/blog/google-ads-for-plumbers/', desc: 'Complete PPC guide for plumbers — keyword strategy, budget benchmarks, and how a call recovery system can capture lost voicemail leads.', date: '2026-06-16', tag: 'Google Ads' },
  { title: 'Meta Ads for Electricians: A Complete Guide to Getting More Customers', path: '/blog/meta-ads-for-electricians/', desc: 'Profitable Facebook ads for electrical contractors — targeting, budgeting, and the #1 missed call problem that kills ROI.', date: '2026-06-16', tag: 'Meta Ads' },
  // Construction estimating guides
  { title: 'The Complete Guide to Construction Estimating for B2B Trades', path: '/tradequote/blog/construction-estimating-guide/', desc: 'Everything you need to know about B2B construction estimating — from material takeoffs to profit margins.', date: '2026-06-16', tag: 'Guide' },
  { title: 'Roofing Cost Estimator: How to Price Commercial Roofing Jobs', path: '/tradequote/blog/roofing-cost-estimator/', desc: 'Learn how to accurately estimate commercial roofing costs including materials, labor, overhead, and profit margin.', date: '2026-06-16', tag: 'Roofing' },
  { title: 'Siding Installation Cost Calculator: A Contractor\'s Guide', path: '/tradequote/blog/siding-installation-cost-calculator/', desc: 'Calculate siding installation costs accurately. Includes material pricing, labor rates, and waste factor calculations.', date: '2026-06-16', tag: 'Siding' },
  { title: 'Concrete Estimating: How to Calculate Material & Labor Costs', path: '/tradequote/blog/concrete-estimating/', desc: 'Master concrete estimating for slabs, footings, columns, and walls. Includes volume calculations and pricing strategies.', date: '2026-06-16', tag: 'Concrete' },
  { title: 'Commercial Bidding: How to Win More Construction Contracts', path: '/tradequote/blog/commercial-bidding/', desc: 'A complete guide to commercial construction bidding. Learn markup strategies, competitive pricing, and proposal best practices.', date: '2026-06-16', tag: 'Bidding' },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Partenaire Croissance Blog",
  "description": "Contractor gear guides, construction estimating, B2B bidding strategies, and business operations tips for trades. Tool reviews, work boots, power stations, and job site equipment compared."
};
---
<BaseLayout title="Guides — Construction Estimating & Home-Service Lead Generation" description="Expert guides on construction estimating, commercial bidding, and paid ads for home-service businesses. Learn how tradies can capture more leads." jsonLd={jsonLd}>
  <section class="hero" style="padding-bottom:2rem">
    <div class="container">
      <h1>Expert Guides <span style="color:#3b82f6">for Trades & Contractors</span></h1>
      <p>Construction estimating guides <span style="color:#64748b">+</span> paid ads playbooks for home-service businesses looking to scale.</p>
    </div>
  </section>

  <section class="container" style="padding-bottom:4rem">
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(350px,1fr));gap:1.5rem">
      {posts.map(post => (
        <a href={post.path} style="text-decoration:none;color:inherit">
          <div class="card blog-card">
            <span class="tag" style="margin-bottom:0.75rem">{post.tag}</span>
            <h3 style="margin-bottom:0.5rem;font-size:1.1rem;color:#e2e8f0">{post.title}</h3>
            <p style="margin:0 0 0.5rem;font-size:0.9rem">{post.desc}</p>
            <span style="font-size:0.8rem;color:#64748b">{post.date}</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
