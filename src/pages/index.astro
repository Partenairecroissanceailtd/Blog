---
import BaseLayout from '../layouts/BaseLayout.astro';

const apps = [
  { title: 'TradeQuote Pro', path: '/tradequote/', desc: '12 trade calculators for construction estimating. Free, zero-login, works offline.', tag: 'Construction', icon: '🏗️', color: '#3b82f6' },
  { title: 'SiteOps Pro', path: '#', desc: '8 calculators for site operations management.', tag: 'Construction', icon: '🏗️', color: '#f97316' },
  { title: 'Real Estate Pro', path: '#', desc: 'Property analysis and investment calculators.', tag: 'Finance', icon: '🏠', color: '#22c55e' },
  { title: 'BizFinance Pro', path: '#', desc: 'Business finance and loan calculators.', tag: 'Finance', icon: '📊', color: '#22c55e' },
  { title: 'CorpTax Pro', path: '#', desc: 'Corporate tax and wealth management tools.', tag: 'Finance', icon: '💰', color: '#22c55e' },
  { title: 'HR/Payroll Pro', path: '#', desc: 'HR and payroll calculators for SMBs.', tag: 'HR', icon: '👥', color: '#06b6d4' },
  { title: 'GovCon Pro', path: '#', desc: 'Government contracting compliance tracker.', tag: 'Compliance', icon: '🏛️', color: '#8b5cf6' },
  { title: 'Legal Deadline Pro', path: '#', desc: 'Statute of limitations and court deadline tracker.', tag: 'Legal', icon: '⚖️', color: '#8b5cf6' },
  { title: 'BizLicensing Pro', path: '#', desc: 'Business license renewal and compliance calendar.', tag: 'Compliance', icon: '📋', color: '#8b5cf6' },
  { title: 'ElderCare Pro', path: '#', desc: 'Care management and documentation tools.', tag: 'Healthcare', icon: '👴', color: '#a855f7' },
  { title: 'HOAManager Pro', path: '#', desc: 'HOA management and property tools.', tag: 'Property', icon: '🏘️', color: '#e94560' },
  { title: 'FleetSafe Pro', path: '#', desc: 'Fleet safety and compliance management.', tag: 'Transport', icon: '🚛', color: '#f97316' },
  { title: 'EnvCompliance Pro', path: '#', desc: 'Environmental compliance and audit tools.', tag: 'Compliance', icon: '♻️', color: '#22c55e' },
  { title: 'GrantManager Pro', path: '#', desc: 'Grant deadline and application tracker.', tag: 'Nonprofit', icon: '📄', color: '#06b6d4' },
  { title: 'ExportPro', path: '#', desc: 'HS code lookup and customs calculator.', tag: 'Trade', icon: '🌍', color: '#22c55e' },
  { title: 'TrademarkIP Pro', path: '#', desc: 'Trademark class lookup and filing tracker.', tag: 'Legal', icon: '©️', color: '#8b5cf6' },
  { title: 'AICompliance Pro', path: '#', desc: 'AI governance and compliance management.', tag: 'Tech', icon: '🤖', color: '#a855f7' },
  { title: 'HeavyOps Pro', path: '#', desc: 'Heavy equipment transport calculators.', tag: 'Transport', icon: '🚜', color: '#f97316' },
  { title: 'AgriOps Pro', path: '#', desc: 'Agriculture business calculators.', tag: 'Agriculture', icon: '🌾', color: '#22c55e' },
  { title: 'KitchenOps Pro', path: '#', desc: 'Commercial kitchen operations tools.', tag: 'Hospitality', icon: '🍳', color: '#e94560' },
  { title: 'CleanOps Pro', path: '#', desc: 'Facility cleaning operations calculators.', tag: 'Services', icon: '🧹', color: '#06b6d4' },
];

const stats = [
  { value: '21', label: 'Professional Tools', desc: 'Free B2B calculators and compliance trackers' },
  { value: '0', label: 'Accounts Required', desc: 'Every tool works instantly, no sign-up needed' },
  { value: '12', label: 'Industries Covered', desc: 'Construction, Legal, Finance, HR, Compliance & more' },
  { value: '500+', label: 'Calls Answered Daily', desc: '24/7 interception of your Google Ads leads in under 3 rings' },
];

const categories = [
  { name: 'Construction & Trades', icon: '🏗️', count: 4, apps: apps.filter(a => ['Construction', 'Transport'].includes(a.tag)) },
  { name: 'Finance & Tax', icon: '💰', count: 3, apps: apps.filter(a => a.tag === 'Finance') },
  { name: 'Compliance & Legal', icon: '⚖️', count: 5, apps: apps.filter(a => ['Compliance', 'Legal'].includes(a.tag)) },
  { name: 'Business Operations', icon: '📊', count: 9, apps: apps.filter(a => ['HR', 'Property', 'Nonprofit', 'Trade', 'Services', 'Tech', 'Agriculture', 'Hospitality'].includes(a.tag)) },
];
const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Partenaire Croissance",
  "url": "https://www.partenairecroissance.com",
  "description": "21 free B2B software tools and a missed call recovery system for home-service businesses running Google Ads.",
  "foundingDate": "2026",
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "sales",
    "email": "ayoub@partenairecroissance.com"
  }
};

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Partenaire Croissance",
  "url": "https://www.partenairecroissance.com",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://www.partenairecroissance.com/?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
};
---
<BaseLayout title="Partenaire Croissance — Free B2B Tools & Missed Call Recovery" description="21 free B2B software tools for contractors, legal, finance & compliance. Plus a missed call recovery system that captures 100% of Google Ads leads 24/7." jsonLd={[orgJsonLd, websiteJsonLd]}>
  <!-- Hero Section -->
  <section style="position:relative;overflow:hidden;padding:5rem 0 4rem;background:linear-gradient(135deg,#0a0f1a 0%,#0f1a2e 50%,#1a0f2e 100%)">
    <div style="position:absolute;top:-50%;right:-20%;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(59,130,246,0.08),transparent 70%);pointer-events:none"></div>
    <div style="position:absolute;bottom:-30%;left:-10%;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(139,92,246,0.06),transparent 70%);pointer-events:none"></div>
    <div class="container" style="position:relative;z-index:1">
      <div style="text-align:center;max-width:800px;margin:0 auto">
        <div style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.5rem 1rem;border-radius:9999px;background:rgba(59,130,246,0.1);border:1px solid rgba(59,130,246,0.2);margin-bottom:2rem;font-size:0.85rem;color:#93c5fd">
          <span>🎉</span>
          <span>21 free B2B tools — no accounts, no data collection, just results</span>
        </div>
        <h1 style="font-size:3.25rem;line-height:1.15;margin-bottom:1.25rem;background:linear-gradient(135deg,#e2e8f0 0%,#3b82f6 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent">Professional B2B Tools.<br />Zero Friction.</h1>
        <p style="font-size:1.2rem;max-width:600px;margin:0 auto 2.25rem;color:#94a3b8;line-height:1.7">21 free calculators and compliance tools for construction, legal, finance, and business professionals. Every tool works instantly — <span style="color:#e2e8f0;font-weight:500">no login, no accounts, no data collection</span>.</p>
        <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
          <a href="/tradequote/" class="btn btn-primary" style="padding:1rem 2rem;font-size:1.05rem">Try TradeQuote Pro →</a>
          <a href="#tools" class="btn btn-outline" style="padding:1rem 2rem;font-size:1.05rem">Browse All Tools</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section style="border-top:1px solid #1e293b;border-bottom:1px solid #1e293b;padding:2.5rem 0">
    <div class="container">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:2rem;text-align:center">
        {stats.map(s => (
          <div>
            <div style="font-size:2.5rem;font-weight:800;background:linear-gradient(135deg,#3b82f6,#8b5cf6);-webkit-background-clip:text;-webkit-text-fill-color:transparent">{s.value}</div>
            <div style="font-size:0.95rem;font-weight:600;color:#e2e8f0;margin-bottom:0.25rem">{s.label}</div>
            <div style="font-size:0.8rem;color:#64748b">{s.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Category Sections -->
  <section id="tools" style="padding:4rem 0">
    <div class="container">
      <h2 style="text-align:center;font-size:2rem;margin-bottom:0.5rem">All Tools by Category</h2>
      <p style="text-align:center;color:#64748b;margin-bottom:3rem;font-size:1.05rem">Free professional tools for every B2B industry</p>

      {categories.map(cat => (
        <div style="margin-bottom:3rem">
          <h3 style="font-size:1.3rem;margin-bottom:1rem;display:flex;align-items:center;gap:0.5rem">
            <span>{cat.icon}</span>
            <span>{cat.name}</span>
            <span style="font-size:0.8rem;color:#64748b;font-weight:400">({cat.count} tools)</span>
          </h3>
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:0.75rem">
            {cat.apps.map(app => (
              <a href={app.path} style="text-decoration:none;color:inherit">
                <div style="background:#1a2332;border:1px solid #2a3a4e;border-radius:0.75rem;padding:1rem 1.25rem;display:flex;align-items:center;gap:0.75rem;transition:all 0.2s;cursor:pointer" 
                     onmouseover="this.style.borderColor='{app.color}';this.style.transform='translateX(4px)'" 
                     onmouseout="this.style.borderColor='#2a3a4e';this.style.transform='translateX(0)'">
                  <span style="font-size:1.5rem">{app.icon}</span>
                  <div style="flex:1">
                    <div style="font-weight:600;color:#e2e8f0;font-size:0.95rem">{app.title}</div>
                    <div style="font-size:0.8rem;color:#64748b">{app.desc}</div>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Missed Call Recovery Section -->
  <section style="padding:4rem 0;background:linear-gradient(135deg,#0a0f1a 0%,#0f1a2e 50%,#1a0f2e 100%);border-top:1px solid #2a3a4e;border-bottom:1px solid #2a3a4e">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center">
        <div>
          <span class="tag" style="background:#22c55e;margin-bottom:1rem">🔥 NEW SERVICE</span>
          <h2 style="font-size:2rem;margin-top:0.5rem;margin-bottom:1rem">Missed Call <span style="color:#22c55e">Revenue Recovery</span></h2>
          <p style="font-size:1.05rem;color:#94a3b8;line-height:1.7">You spend <strong style="color:#e2e8f0">$200–$600</strong> in Google Ads to generate each phone call. But <strong style="color:#e94560">72% of homeowners hang up without leaving a message</strong> when they reach voicemail. They call your competitor instead.</p>
          <p style="font-size:1.05rem;color:#94a3b8;line-height:1.7">Our system answers every call in <strong style="color:#e2e8f0">under 3 rings</strong>, 24/7, in perfect French — then qualifies the lead and books it directly into your calendar.</p>
          <ul style="margin-bottom:1.5rem">
            <li><strong style="color:#e2e8f0">✓</strong> Answers in &lt;3 rings — no more lost calls to voicemail</li>
            <li><strong style="color:#e2e8f0">✓</strong> Qualifies caller: verifies homeowner, postal code, work type</li>
            <li><strong style="color:#e2e8f0">✓</strong> Books qualified appointments directly in your calendar</li>
            <li><strong style="color:#e2e8f0">✓</strong> Every call recorded & transcribed — Law 25 compliant</li>
            <li><strong style="color:#e2e8f0">✓</strong> You only pay $25 per qualified appointment delivered</li>
          </ul>
          <div style="display:flex;gap:1rem;flex-wrap:wrap">
            <a href="/sdr/" class="btn btn-primary" style="padding:0.85rem 2rem;background:#22c55e">Book a Demo →</a>
            <a href="#pricing" class="btn btn-outline" style="padding:0.85rem 2rem;border-color:#22c55e;color:#22c55e">See Pricing</a>
          </div>
        </div>
        <div style="background:#1a2332;border:1px solid #2a3a4e;border-radius:1rem;padding:2rem">
          <h3 style="margin-top:0;color:#e2e8f0;font-size:1.15rem">📞 How It Works</h3>
          <div style="display:flex;flex-direction:column;gap:1.25rem;margin-top:1.25rem">
            <div style="display:flex;gap:1rem">
              <div style="width:36px;height:36px;border-radius:9999px;background:#15803d;display:flex;align-items:center;justify-content:center;font-weight:700;flex-shrink:0;font-size:0.9rem">1</div>
              <div><strong style="color:#e2e8f0">Call comes in from Google Ads</strong><br /><span style="font-size:0.9rem;color:#94a3b8">Our system answers before the 3rd ring — even when you're on a job site or the office is closed</span></div>
            </div>
            <div style="display:flex;gap:1rem">
              <div style="width:36px;height:36px;border-radius:9999px;background:#15803d;display:flex;align-items:center;justify-content:center;font-weight:700;flex-shrink:0;font-size:0.9rem">2</div>
              <div><strong style="color:#e2e8f0">AI qualification in real-time</strong><br /><span style="font-size:0.9rem;color:#94a3b8">Verifies homeowner status, postal code (service area), and type of work needed — filters out noise</span></div>
            </div>
            <div style="display:flex;gap:1rem">
              <div style="width:36px;height:36px;border-radius:9999px;background:#15803d;display:flex;align-items:center;justify-content:center;font-weight:700;flex-shrink:0;font-size:0.9rem">3</div>
              <div><strong style="color:#e2e8f0">Appointment booked in your calendar</strong><br /><span style="font-size:0.9rem;color:#94a3b8">Qualified lead with full details synced to your CRM. Audio recording available for 48h dispute window</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Section -->
  <section style="padding:4rem 0;background:linear-gradient(0deg,rgba(59,130,246,0.03),transparent)">
    <div class="container">
      <h2 style="text-align:center;font-size:2rem;margin-bottom:3rem">Why Partenaire Croissance?</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem">
        {[
          { icon: '⚡', title: 'Zero Friction', desc: 'Every tool works instantly. Open, use, done. No accounts, no onboarding, no data collection.' },
          { icon: '🎯', title: 'Industry-Specific', desc: 'Built for real B2B workflows — construction estimating, legal compliance, financial analysis, HR management.' },
          { icon: '📱', title: 'Android + PWA', desc: 'Install as native Android apps or use in browser. Work offline. Your data stays on your device.' },
          { icon: '🔒', title: '100% Private', desc: 'All calculations happen locally. No servers, no tracking, no data leaves your device. Ever.' },
          { icon: '🔄', title: 'Always Free', desc: 'Every tool is completely free. No freemium tiers, no limited trials, no credit card required.' },
          { icon: '📊', title: 'Professional Output', desc: 'Generate PDF quotes, export compliance reports, and produce professional-grade documentation.' },
        ].map(f => (
          <div class="card" style="text-align:center;padding:2rem 1.5rem">
            <div style="font-size:2.5rem;margin-bottom:0.75rem">{f.icon}</div>
            <h3 style="margin-bottom:0.5rem;font-size:1.1rem">{f.title}</h3>
            <p style="margin:0;font-size:0.9rem">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="padding:4rem 0;text-align:center">
    <div class="container">
      <div style="background:linear-gradient(135deg,#1a2332,#0f1a2e);border:1px solid #2a3a4e;border-radius:1.5rem;padding:3rem 2rem;max-width:700px;margin:0 auto">
        <h2 style="font-size:1.75rem;margin-bottom:0.75rem">Stop Losing Google Ads Revenue to Voicemail</h2>
        <p style="color:#94a3b8;margin-bottom:2rem;max-width:500px;margin-left:auto;margin-right:auto">Capture 100% of your calls 24/7. Only $25 per qualified appointment booked in your calendar.</p>
        <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
          <a href="/sdr/" class="btn btn-primary" style="padding:1rem 2.5rem;font-size:1.05rem;background:#22c55e">Book a Demo →</a>
          <a href="/blog/" class="btn btn-outline" style="padding:1rem 2.5rem;font-size:1.05rem">Read Our Guides</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
