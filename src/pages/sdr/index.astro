---
import BaseLayout from '../../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "AI SDR Lead Enrichment for Home-Service Businesses",
  "description": "Identify home-service businesses running Meta and Google Ads, enrich with decision-maker contacts, and deliver personalized outreach sequences.",
  "provider": { "@type": "Organization", "name": "Partenaire Croissance" }
};
---
<BaseLayout title="AI SDR — Lead Enrichment for Tradies & Home-Service Businesses" description="We find plumbers, electricians, HVAC, and home-service businesses actively running Meta/Google Ads — then enrich with contacts, ad data, and personalized email drafts." jsonLd={jsonLd}>
  <!-- Hero -->
  <section style="position:relative;overflow:hidden;padding:5rem 0 4rem;background:linear-gradient(135deg,#0a0f1a 0%,#0f1a2e 50%,#1a0f2e 100%)">
    <div style="position:absolute;top:-30%;right:-10%;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(139,92,246,0.08),transparent 70%);pointer-events:none"></div>
    <div class="container" style="position:relative;z-index:1">
      <div style="text-align:center;max-width:750px;margin:0 auto">
        <span class="tag" style="background:#8b5cf6;margin-bottom:1rem">AI-POWERED B2B LEAD ENRICHMENT</span>
        <h1 style="font-size:3rem;line-height:1.15;margin-bottom:1.25rem;background:linear-gradient(135deg,#e2e8f0 0%,#8b5cf6 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-top:1rem">Turn Tradie Lists Into<br /> Qualified Sales Leads</h1>
        <p style="font-size:1.15rem;max-width:600px;margin:0 auto 2.25rem;color:#94a3b8;line-height:1.7">Upload a CSV of home-service businesses. We find <strong style="color:#e2e8f0">who's running paid ads</strong>, enrich with decision-maker contacts, and deliver personalized outreach emails — ready to copy, paste, and send.</p>
        <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
          <a href="#contact" class="btn btn-primary" style="padding:1rem 2.5rem;font-size:1.05rem">Start Your Campaign →</a>
          <a href="#how-it-works" class="btn btn-outline" style="padding:1rem 2.5rem;font-size:1.05rem">How It Works</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section style="border-top:1px solid #1e293b;border-bottom:1px solid #1e293b;padding:2.5rem 0">
    <div class="container">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:2rem;text-align:center">
        <div>
          <div style="font-size:2.5rem;font-weight:800;background:linear-gradient(135deg,#8b5cf6,#3b82f6);-webkit-background-clip:text;-webkit-text-fill-color:transparent">500+</div>
          <div style="font-size:0.95rem;font-weight:600;color:#e2e8f0;margin-bottom:0.25rem">Leads Enriched / Month</div>
          <div style="font-size:0.8rem;color:#64748b">Verified active advertisers in your area</div>
        </div>
        <div>
          <div style="font-size:2.5rem;font-weight:800;background:linear-gradient(135deg,#8b5cf6,#3b82f6);-webkit-background-clip:text;-webkit-text-fill-color:transparent">30%</div>
          <div style="font-size:0.95rem;font-weight:600;color:#e2e8f0;margin-bottom:0.25rem">Avg. Reply Rate</div>
          <div style="font-size:0.8rem;color:#64748b">Personalized outreach that actually gets responses</div>
        </div>
        <div>
          <div style="font-size:2.5rem;font-weight:800;background:linear-gradient(135deg,#8b5cf6,#3b82f6);-webkit-background-clip:text;-webkit-text-fill-color:transparent">48h</div>
          <div style="font-size:0.95rem;font-weight:600;color:#e2e8f0;margin-bottom:0.25rem">Turnaround Time</div>
          <div style="font-size:0.8rem;color:#64748b">CSV in your hands within 2 business days</div>
        </div>
        <div>
          <div style="font-size:2.5rem;font-weight:800;background:linear-gradient(135deg,#8b5cf6,#3b82f6);-webkit-background-clip:text;-webkit-text-fill-color:transparent">3x</div>
          <div style="font-size:0.95rem;font-weight:600;color:#e2e8f0;margin-bottom:0.25rem">Faster Outreach</div>
          <div style="font-size:0.8rem;color:#64748b">Ready-to-use email sequences save hours of research</div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section id="how-it-works" style="padding:4rem 0">
    <div class="container">
      <h2 style="text-align:center;font-size:2rem;margin-bottom:0.5rem">How It Works</h2>
      <p style="text-align:center;color:#64748b;margin-bottom:3rem;font-size:1.05rem">Three steps from raw list to qualified pipeline</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:1.5rem">
        <div class="card" style="padding:2rem">
          <div style="width:48px;height:48px;border-radius:9999px;background:#1d4ed8;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:1.25rem;margin-bottom:1.25rem">1</div>
          <h3 style="margin-top:0;color:#e2e8f0">Upload Your Target List</h3>
          <p>Send us a CSV with business names, city/province, and website (optional). We accept plumbers, electricians, HVAC, roofers, landscapers, painters — any home-service trade.</p>
        </div>
        <div class="card" style="padding:2rem">
          <div style="width:48px;height:48px;border-radius:9999px;background:#1d4ed8;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:1.25rem;margin-bottom:1.25rem">2</div>
          <h3 style="margin-top:0;color:#e2e8f0">AI Scans for Active Ads</h3>
          <p>Our system checks Meta Ad Library and Google Ads Transparency for each business. We identify who's running paid campaigns right now — those are your prime targets.</p>
        </div>
        <div class="card" style="padding:2rem">
          <div style="width:48px;height:48px;border-radius:9999px;background:#1d4ed8;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:1.25rem;margin-bottom:1.25rem">3</div>
          <h3 style="margin-top:0;color:#e2e8f0">Get Enriched CSV + Emails</h3>
          <p>Receive a CSV with business name, domain, Facebook Page URL, decision-maker name, phone, email, and a personalized 3-touch email sequence pointing out their ad conversion gaps.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What You Get -->
  <section style="padding:4rem 0;background:linear-gradient(0deg,rgba(139,92,246,0.03),transparent)">
    <div class="container">
      <h2 style="text-align:center;font-size:2rem;margin-bottom:3rem">What's In Your CSV</h2>
      <div style="background:#1a2332;border:1px solid #2a3a4e;border-radius:0.75rem;overflow:hidden;max-width:800px;margin:0 auto">
        <div style="padding:1rem 1.5rem;border-bottom:1px solid #2a3a4e">
          <code style="color:#3b82f6">Business Name</code> <span style="color:#64748b">|</span>
          <code style="color:#22c55e">Domain</code> <span style="color:#64748b">|</span>
          <code style="color:#f97316">Facebook Page</code> <span style="color:#64748b">|</span>
          <code style="color:#e94560">Has Active Ads?</code> <span style="color:#64748b">|</span>
          <code style="color:#06b6d4">Ad Platform</code> <span style="color:#64748b">|</span>
          <code style="color:#a855f7">Decision Maker</code> <span style="color:#64748b">|</span>
          <code style="color:#e2e8f0">Phone</code> <span style="color:#64748b">|</span>
          <code style="color:#e2e8f0">Email</code>
        </div>
        <div style="padding:1rem 1.5rem">
          <div style="font-size:0.85rem;color:#94a3b8;font-family:monospace;line-height:1.8">
            ACME Plumbing | acmeplumbing.ca | fb.com/acmeplumbing | YES | Meta + Google | Mark Johnson | 514-555-0101 | mark@acmeplumbing.ca<br />
            <span style="color:#3b82f6">✉ Email Draft 1: \"Hi Mark, noticed ACME is running active Meta & Google ads for emergency plumbing services — great move. I analyzed your landing page funnel and see an opportunity to..."</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section style="padding:4rem 0">
    <div class="container">
      <h2 style="text-align:center;font-size:2rem;margin-bottom:3rem">Who Is This For?</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem">
        <div class="card" style="text-align:center;padding:2rem 1.5rem">
          <div style="font-size:2.5rem;margin-bottom:0.75rem">📞</div>
          <h3 style="margin-bottom:0.5rem;font-size:1.1rem;color:#e2e8f0">Cold Callers</h3>
          <p style="margin:0;font-size:0.9rem">Stop dialing from directories. Call tradies who already invest in ads — they understand ROI and are ready to talk about lead generation.</p>
        </div>
        <div class="card" style="text-align:center;padding:2rem 1.5rem">
          <div style="font-size:2.5rem;margin-bottom:0.75rem">📧</div>
          <h3 style="margin-bottom:0.5rem;font-size:1.1rem;color:#e2e8f0">Email Outreach Teams</h3>
          <p style="margin:0;font-size:0.9rem">Drop the generic templates. Our AI drafts hyper-personalized emails referencing each business's actual ad spend and conversion gaps.</p>
        </div>
        <div class="card" style="text-align:center;padding:2rem 1.5rem">
          <div style="font-size:2.5rem;margin-bottom:0.75rem">🏢</div>
          <h3 style="margin-bottom:0.5rem;font-size:1.1rem;color:#e2e8f0">Marketing Agencies</h3>
          <p style="margin:0;font-size:0.9rem">Identify tradies burning ad budget on poorly optimized campaigns. Pitch your agency services with proof they're already spending.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section style="padding:4rem 0;background:linear-gradient(0deg,rgba(59,130,246,0.03),transparent);border-top:1px solid #1e293b">
    <div class="container">
      <h2 style="text-align:center;font-size:2rem;margin-bottom:0.5rem">Simple Pricing</h2>
      <p style="text-align:center;color:#64748b;margin-bottom:3rem;font-size:1.05rem">Pay only for what you need</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem;max-width:900px;margin:0 auto">
        <div class="card" style="padding:2rem;text-align:center;border:1px solid #2a3a4e">
          <h3 style="margin-top:0;color:#e2e8f0">Starter</h3>
          <div style="font-size:3rem;font-weight:800;color:#e2e8f0;margin:1rem 0">$97</div>
          <div style="color:#64748b;margin-bottom:1.5rem;font-size:0.9rem">Per list of 100 leads</div>
          <ul style="text-align:left;font-size:0.9rem">
            <li>100 tradies scanned for active ads</li>
            <li>Decision-maker contact enrichment</li>
            <li>Personalized 3-touch email drafts</li>
            <li>Delivered as CSV within 48h</li>
          </ul>
          <a href="#contact" class="btn btn-primary" style="padding:0.75rem 2rem;width:100%;justify-content:center;margin-top:1.5rem">Order Now</a>
        </div>
        <div class="card" style="padding:2rem;text-align:center;border:1px solid #8b5cf6;position:relative">
          <span style="position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:#8b5cf6;color:#fff;padding:0.25rem 1rem;border-radius:9999px;font-size:0.8rem;font-weight:600">MOST POPULAR</span>
          <h3 style="margin-top:0;color:#e2e8f0">Scale</h3>
          <div style="font-size:3rem;font-weight:800;color:#e2e8f0;margin:1rem 0">$247</div>
          <div style="color:#64748b;margin-bottom:1.5rem;font-size:0.9rem">Per list of 300 leads</div>
          <ul style="text-align:left;font-size:0.9rem">
            <li>300 tradies scanned for active ads</li>
            <li>Decision-maker contact enrichment</li>
            <li>Personalized 3-touch email drafts</li>
            <li>Priority 24h delivery</li>
            <li>Export to CSV + Google Sheets</li>
          </ul>
          <a href="#contact" class="btn btn-primary" style="padding:0.75rem 2rem;width:100%;justify-content:center;margin-top:1.5rem">Order Now</a>
        </div>
        <div class="card" style="padding:2rem;text-align:center;border:1px solid #2a3a4e">
          <h3 style="margin-top:0;color:#e2e8f0">Enterprise</h3>
          <div style="font-size:3rem;font-weight:800;color:#e2e8f0;margin:1rem 0">Custom</div>
          <div style="color:#64748b;margin-bottom:1.5rem;font-size:0.9rem">1,000+ leads / month</div>
          <ul style="text-align:left;font-size:0.9rem">
            <li>Custom territory & trade targeting</li>
            <li>API integration for continuous enrichment</li>
            <li>Dedicated account manager</li>
            <li>Weekly refreshed lead lists</li>
            <li>Priority support</li>
          </ul>
          <a href="#contact" class="btn btn-outline" style="padding:0.75rem 2rem;width:100%;justify-content:center;margin-top:1.5rem">Contact Us</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact / Lead Form -->
  <section id="contact" style="padding:4rem 0">
    <div class="container">
      <div style="max-width:600px;margin:0 auto;background:#1a2332;border:1px solid #2a3a4e;border-radius:1rem;padding:2.5rem">
        <h2 style="text-align:center;font-size:1.75rem;margin-top:0;margin-bottom:0.5rem">Get Your Lead List</h2>
        <p style="text-align:center;color:#64748b;margin-bottom:2rem">Fill in the form below and we'll get back to you within 24 hours</p>
        <form action="https://api.web3forms.com/submit" method="POST">
          <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_KEY_HERE" />
          <input type="hidden" name="subject" value="New AI SDR Lead Enquiry" />
          <input type="hidden" name="redirect" value="https://www.partenairecroissance.com/sdr/thank-you/" />

          <div style="margin-bottom:1.25rem">
            <label style="display:block;font-size:0.9rem;color:#e2e8f0;margin-bottom:0.4rem;font-weight:600">Your Name</label>
            <input type="text" name="name" required style="width:100%;padding:0.75rem 1rem;border-radius:0.5rem;border:1px solid #2a3a4e;background:#0a0f1a;color:#e2e8f0;font-size:0.95rem" placeholder="John Smith" />
          </div>

          <div style="margin-bottom:1.25rem">
            <label style="display:block;font-size:0.9rem;color:#e2e8f0;margin-bottom:0.4rem;font-weight:600">Business Email</label>
            <input type="email" name="email" required style="width:100%;padding:0.75rem 1rem;border-radius:0.5rem;border:1px solid #2a3a4e;background:#0a0f1a;color:#e2e8f0;font-size:0.95rem" placeholder="john@yourcompany.com" />
          </div>

          <div style="margin-bottom:1.25rem">
            <label style="display:block;font-size:0.9rem;color:#e2e8f0;margin-bottom:0.4rem;font-weight:600">Phone Number</label>
            <input type="tel" name="phone" required style="width:100%;padding:0.75rem 1rem;border-radius:0.5rem;border:1px solid #2a3a4e;background:#0a0f1a;color:#e2e8f0;font-size:0.95rem" placeholder="+1 514-555-0100" />
          </div>

          <div style="margin-bottom:1.25rem">
            <label style="display:block;font-size:0.9rem;color:#e2e8f0;margin-bottom:0.4rem;font-weight:600">Target Trade(s)</label>
            <select name="trade" style="width:100%;padding:0.75rem 1rem;border-radius:0.5rem;border:1px solid #2a3a4e;background:#0a0f1a;color:#e2e8f0;font-size:0.95rem">
              <option value="">Select...</option>
              <option value="Plumbers">Plumbers</option>
              <option value="Electricians">Electricians</option>
              <option value="HVAC">HVAC</option>
              <option value="Roofers">Roofers</option>
              <option value="Landscapers">Landscapers</option>
              <option value="Painters">Painters</option>
              <option value="General Contractors">General Contractors</option>
              <option value="Multiple">Multiple Trades</option>
            </select>
          </div>

          <div style="margin-bottom:1.25rem">
            <label style="display:block;font-size:0.9rem;color:#e2e8f0;margin-bottom:0.4rem;font-weight:600">Target City / Region</label>
            <input type="text" name="location" style="width:100%;padding:0.75rem 1rem;border-radius:0.5rem;border:1px solid #2a3a4e;background:#0a0f1a;color:#e2e8f0;font-size:0.95rem" placeholder="e.g. Montreal, Quebec" />
          </div>

          <div style="margin-bottom:1.5rem">
            <label style="display:block;font-size:0.9rem;color:#e2e8f0;margin-bottom:0.4rem;font-weight:600">How many leads?</label>
            <select name="quantity" style="width:100%;padding:0.75rem 1rem;border-radius:0.5rem;border:1px solid #2a3a4e;background:#0a0f1a;color:#e2e8f0;font-size:0.95rem">
              <option value="100">100 leads ($97)</option>
              <option value="300" selected>300 leads ($247)</option>
              <option value="1000">1,000+ (Enterprise)</option>
            </select>
          </div>

          <div>
            <div style="display:flex;justify-content:center">
              <div class="g-recaptcha" data-sitekey="YOUR_RECAPTCHA_SITE_KEY"></div>
            </div>
            <script src="https://www.google.com/recaptcha/api.js"></script>
          </div>

          <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:1rem;font-size:1.05rem;margin-top:1.5rem">Send Enquiry →</button>
        </form>
        <p style="text-align:center;font-size:0.8rem;color:#64748b;margin-top:1rem">Or call us directly: <strong style="color:#e2e8f0">+1 (514) 555-XXXX</strong> | <strong style="color:#e2e8f0">ayoub@partenairecroissance.com</strong></p>
      </div>
    </div>
  </section>
</BaseLayout>
