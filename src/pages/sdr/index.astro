---
import BaseLayout from '../../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Missed Call Revenue Recovery for Home-Service Businesses",
  "description": "24/7 call answering system that captures 100% of ad leads, qualifies callers, and books appointments directly into your calendar.",
  "provider": { "@type": "Organization", "name": "Partenaire Croissance" }
};
---
<BaseLayout title="Missed Call Revenue Recovery — Capture 100% of Ad Leads" description="Stop losing ad calls to voicemail. Our system answers 24/7 in under 3 rings, qualifies callers, and books appointments. Only $25 per qualified appointment." jsonLd={jsonLd}>
  <!-- Hero -->
  <section style="position:relative;overflow:hidden;padding:5rem 0 4rem;background:linear-gradient(135deg,#0a0f1a 0%,#0f1a2e 50%,#052e16 100%)">
    <div style="position:absolute;top:-30%;right:-10%;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(34,197,94,0.08),transparent 70%);pointer-events:none"></div>
    <div class="container" style="position:relative;z-index:1">
      <div style="text-align:center;max-width:750px;margin:0 auto">
        <span class="tag" style="background:#22c55e;margin-bottom:1rem">MISSED CALL REVENUE RECOVERY</span>
        <h1 style="font-size:3rem;line-height:1.15;margin-bottom:1.25rem;background:linear-gradient(135deg,#e2e8f0 0%,#22c55e 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-top:1rem">Stop Losing $200–$600<br /> Per Missed Call</h1>
        <p style="font-size:1.15rem;max-width:600px;margin:0 auto 2.25rem;color:#94a3b8;line-height:1.7">You spend good money on ads. But <strong style="color:#e94560">72% of homeowners hang up</strong> without leaving a message when they reach voicemail. Our system answers every call in under 3 rings, 24/7 — in perfect French — and books qualified appointments straight into your calendar.</p>
        <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
          <a href="#contact" class="btn btn-primary" style="padding:1rem 2.5rem;font-size:1.05rem;background:#22c55e">Book a Demo →</a>
          <a href="#how-it-works" class="btn btn-outline" style="padding:1rem 2.5rem;font-size:1.05rem">How It Works</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section style="border-top:1px solid #1e293b;border-bottom:1px solid #1e293b;padding:2.5rem 0">
    <div class="container">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:2rem;text-align:center">
        <div>
          <div style="font-size:2.5rem;font-weight:800;background:linear-gradient(135deg,#22c55e,#3b82f6);-webkit-background-clip:text;-webkit-text-fill-color:transparent">72%</div>
          <div style="font-size:0.95rem;font-weight:600;color:#e2e8f0;margin-bottom:0.25rem">Calls Lost to Voicemail</div>
          <div style="font-size:0.8rem;color:#64748b">Homeowners hang up instead of leaving a message</div>
        </div>
        <div>
          <div style="font-size:2.5rem;font-weight:800;background:linear-gradient(135deg,#22c55e,#3b82f6);-webkit-background-clip:text;-webkit-text-fill-color:transparent">&lt;3s</div>
          <div style="font-size:0.95rem;font-weight:600;color:#e2e8f0;margin-bottom:0.25rem">Answer Time</div>
          <div style="font-size:0.8rem;color:#64748b">System picks up before the 3rd ring</div>
        </div>
        <div>
          <div style="font-size:2.5rem;font-weight:800;background:linear-gradient(135deg,#22c55e,#3b82f6);-webkit-background-clip:text;-webkit-text-fill-color:transparent">24/7</div>
          <div style="font-size:0.95rem;font-weight:600;color:#e2e8f0;margin-bottom:0.25rem">Coverage</div>
          <div style="font-size:0.8rem;color:#64748b">Nights, weekends, holidays — never miss a lead</div>
        </div>
        <div>
          <div style="font-size:2.5rem;font-weight:800;background:linear-gradient(135deg,#22c55e,#3b82f6);-webkit-background-clip:text;-webkit-text-fill-color:transparent">$25</div>
          <div style="font-size:0.95rem;font-weight:600;color:#e2e8f0;margin-bottom:0.25rem">Per Qualified Appointment</div>
          <div style="font-size:0.8rem;color:#64748b">You only pay when the client is in your calendar</div>
        </div>
      </div>
    </div>
  </section>

  <!-- The Problem -->
  <section style="padding:4rem 0">
    <div class="container">
      <div style="max-width:800px;margin:0 auto;text-align:center">
        <h2 style="font-size:2rem;margin-bottom:1rem">The Hidden Cost of Missed Calls</h2>
        <p style="font-size:1.1rem;color:#94a3b8;margin-bottom:2rem">Every ad call you miss is revenue walking out the door — straight to your competitor.</p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem;max-width:900px;margin:0 auto">
        <div class="card" style="text-align:center;padding:2rem 1.5rem;border-color:#e94560">
          <div style="font-size:3rem;margin-bottom:0.75rem">💸</div>
          <h3 style="margin-bottom:0.5rem;color:#e2e8f0">$200–$600 Per Call</h3>
          <p style="margin:0;font-size:0.9rem">That's what you spend on ads to generate each inbound phone call. When it goes to voicemail, that investment is wasted.</p>
        </div>
        <div class="card" style="text-align:center;padding:2rem 1.5rem;border-color:#e94560">
          <div style="font-size:3rem;margin-bottom:0.75rem">📉</div>
          <h3 style="margin-bottom:0.5rem;color:#e2e8f0">72% Hang Up on Voicemail</h3>
          <p style="margin:0;font-size:0.9rem">Homeowners calling for urgent service don't leave messages. They call the next business on Google — your competitor gets the job.</p>
        </div>
        <div class="card" style="text-align:center;padding:2rem 1.5rem;border-color:#e94560">
          <div style="font-size:3rem;margin-bottom:0.75rem">🕐</div>
          <h3 style="margin-bottom:0.5rem;color:#e2e8f0">Your Team Is on Job Sites</h3>
          <p style="margin:0;font-size:0.9rem">During lunch, after 5 PM, and on weekends — that's when most emergency calls come in. Your team can't be at the desk 24/7.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section id="how-it-works" style="padding:4rem 0;background:linear-gradient(0deg,rgba(34,197,94,0.03),transparent);border-top:1px solid #1e293b;border-bottom:1px solid #1e293b">
    <div class="container">
      <h2 style="text-align:center;font-size:2rem;margin-bottom:0.5rem">How It Works</h2>
      <p style="text-align:center;color:#64748b;margin-bottom:3rem;font-size:1.05rem">Three simple steps from missed call to booked appointment</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:1.5rem">
        <div class="card" style="padding:2rem">
          <div style="width:48px;height:48px;border-radius:9999px;background:#15803d;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:1.25rem;margin-bottom:1.25rem">1</div>
          <h3 style="margin-top:0;color:#e2e8f0">Call Comes In</h3>
          <p>Prospect calls from your Google Ad. Our system answers in <strong style="color:#e2e8f0">under 3 rings</strong> with a warm, professional greeting in perfect French (Loi 96 compliant).</p>
        </div>
        <div class="card" style="padding:2rem">
          <div style="width:48px;height:48px;border-radius:9999px;background:#15803d;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:1.25rem;margin-bottom:1.25rem">2</div>
          <h3 style="margin-top:0;color:#e2e8f0">AI Qualification</h3>
          <p>Our AI asks the right questions: Are you the homeowner? What's your postal code? What type of work do you need? We filter out wrong numbers and out-of-area callers automatically.</p>
        </div>
        <div class="card" style="padding:2rem">
          <div style="width:48px;height:48px;border-radius:9999px;background:#15803d;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:1.25rem;margin-bottom:1.25rem">3</div>
          <h3 style="margin-top:0;color:#e2e8f0">Appointment Booked</h3>
          <p>Qualified appointment with full details synced to your calendar. Audio recording available for review. Only <strong style="color:#e2e8f0">$25 per qualified appointment</strong> — nothing for bad leads or no-shows.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Fees Explained -->
  <section style="padding:4rem 0">
    <div class="container">
      <h2 style="text-align:center;font-size:2rem;margin-bottom:0.5rem">What You Pay vs. What's Free</h2>
      <p style="text-align:center;color:#64748b;margin-bottom:3rem;font-size:1.05rem">Transparent pricing — you only pay for real, qualified appointments</p>
      <div style="background:#1a2332;border:1px solid #2a3a4e;border-radius:0.75rem;overflow:hidden;max-width:700px;margin:0 auto">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0;border-bottom:1px solid #2a3a4e">
          <div style="padding:1rem 1.5rem;font-weight:600;color:#22c55e;background:rgba(34,197,94,0.05)">✅ Rendez-vous Facturable ($25)</div>
          <div style="padding:1rem 1.5rem;color:#94a3b8">Verified homeowner, in your zone, explicit quote request</div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0;border-bottom:1px solid #2a3a4e">
          <div style="padding:1rem 1.5rem;font-weight:600;color:#94a3b8">🆓 Rendez-vous Gratuit ($0)</div>
          <div style="padding:1rem 1.5rem;color:#94a3b8">Free consultation or estimate requests</div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0;border-bottom:1px solid #2a3a4e">
          <div style="padding:1rem 1.5rem;font-weight:600;color:#94a3b8">🆓 Hors zone / Mauvais numéros</div>
          <div style="padding:1rem 1.5rem;color:#94a3b8">Out of service area or wrong numbers — $0</div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0">
          <div style="padding:1rem 1.5rem;font-weight:600;color:#94a3b8">🆓 No-Show / Contestation</div>
          <div style="padding:1rem 1.5rem;color:#94a3b8">48h dispute window with full audio proof</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section id="pricing" style="padding:4rem 0;background:linear-gradient(0deg,rgba(34,197,94,0.03),transparent);border-top:1px solid #1e293b">
    <div class="container">
      <h2 style="text-align:center;font-size:2rem;margin-bottom:0.5rem">Simple Pricing</h2>
      <p style="text-align:center;color:#64748b;margin-bottom:3rem;font-size:1.05rem">One setup fee. Two ways to pay. Zero risk.</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:1.5rem;max-width:750px;margin:0 auto">
        <div class="card" style="padding:2rem;text-align:center;border:1px solid #22c55e;position:relative">
          <span style="position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:#22c55e;color:#fff;padding:0.25rem 1rem;border-radius:9999px;font-size:0.8rem;font-weight:600">⭐ RECOMMENDED</span>
          <h3 style="margin-top:0;color:#e2e8f0">Option A: Performance</h3>
          <div style="font-size:1rem;color:#64748b;margin:0.5rem 0">Setup Fee</div>
          <div style="font-size:2.5rem;font-weight:800;color:#e2e8f0">$1,300</div>
          <div style="color:#64748b;font-size:0.85rem;margin-bottom:1.5rem">One-time (configuration, scripts, CRM/calendar integration)</div>
          <div style="font-size:1rem;color:#64748b;margin:0.5rem 0">Then</div>
          <div style="font-size:2.5rem;font-weight:800;color:#22c55e">$25</div>
          <div style="color:#64748b;font-size:0.85rem;margin-bottom:1.5rem">Per qualified appointment delivered</div>
          <ul style="text-align:left;font-size:0.9rem">
            <li>24/7 call answering in &lt;3 rings</li>
            <li>AI qualification (homeowner, zone, work type)</li>
            <li>Calendar sync + audio recording</li>
            <li>48h dispute window with proof</li>
            <li>Law 25 & Loi 96 compliant</li>
            <li>Pay only for real appointments</li>
          </ul>
          <a href="#contact" class="btn btn-primary" style="padding:0.75rem 2rem;width:100%;justify-content:center;margin-top:1.5rem;background:#22c55e">Get Started →</a>
        </div>
        <div class="card" style="padding:2rem;text-align:center;border:1px solid #2a3a4e">
          <h3 style="margin-top:0;color:#e2e8f0">Option B: Unlimited</h3>
          <div style="font-size:1rem;color:#64748b;margin:0.5rem 0">Setup Fee</div>
          <div style="font-size:2.5rem;font-weight:800;color:#e2e8f0">$1,300</div>
          <div style="color:#64748b;font-size:0.85rem;margin-bottom:1.5rem">One-time (configuration, scripts, CRM/calendar integration)</div>
          <div style="font-size:1rem;color:#64748b;margin:0.5rem 0">Then</div>
          <div style="font-size:2.5rem;font-weight:800;color:#e2e8f0">$997</div>
          <div style="color:#64748b;font-size:0.85rem;margin-bottom:1.5rem">/ month — unlimited calls & appointments</div>
          <ul style="text-align:left;font-size:0.9rem">
            <li>Everything in Performance plan</li>
            <li>Unlimited call volume</li>
            <li>Unlimited booked appointments</li>
            <li>Priority support</li>
            <li>Custom scripts & workflows</li>
            <li>Dedicated onboarding</li>
          </ul>
          <a href="#contact" class="btn btn-outline" style="padding:0.75rem 2rem;width:100%;justify-content:center;margin-top:1.5rem">Contact Us</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Compliance -->
  <section style="padding:4rem 0">
    <div class="container">
      <div style="max-width:800px;margin:0 auto">
        <h2 style="text-align:center;font-size:1.75rem;margin-bottom:2rem">Data Security & Compliance</h2>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:1.5rem">
          <div class="card" style="padding:1.5rem">
            <div style="font-size:1.5rem;margin-bottom:0.5rem">🔊</div>
            <h3 style="margin-top:0;font-size:1rem;color:#e2e8f0">Loi 96 Compliant</h3>
            <p style="margin:0;font-size:0.85rem">All calls answered in perfect French with proper notice of collection at the start of every call.</p>
          </div>
          <div class="card" style="padding:1.5rem">
            <div style="font-size:1.5rem;margin-bottom:0.5rem">🗑️</div>
            <h3 style="margin-top:0;font-size:1rem;color:#e2e8f0">Law 25 Compliant</h3>
            <p style="margin:0;font-size:0.85rem">Audio data automatically destroyed or anonymized after 30 days. Full traceability log for regulatory audits.</p>
          </div>
          <div class="card" style="padding:1.5rem">
            <div style="font-size:1.5rem;margin-bottom:0.5rem">🔐</div>
            <h3 style="margin-top:0;font-size:1rem;color:#e2e8f0">Secure Hosting</h3>
            <p style="margin:0;font-size:0.85rem">All data hosted securely in Canada. Complete audit trail available for regulatory compliance.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section id="contact" style="padding:4rem 0;background:linear-gradient(0deg,rgba(34,197,94,0.03),transparent);border-top:1px solid #1e293b">
    <div class="container">
      <div style="max-width:600px;margin:0 auto;background:#1a2332;border:1px solid #2a3a4e;border-radius:1rem;padding:2.5rem">
        <h2 style="text-align:center;font-size:1.75rem;margin-top:0;margin-bottom:0.5rem">Book a Free Demo</h2>
        <p style="text-align:center;color:#64748b;margin-bottom:2rem">See how many calls you're missing — and how much revenue we can recover</p>
        <form action="https://api.web3forms.com/submit" method="POST">
          <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_KEY_HERE" />
          <input type="hidden" name="subject" value="New Call Recovery Demo Request" />
          <input type="hidden" name="redirect" value="https://www.partenairecroissance.com/sdr/thank-you/" />

          <div style="margin-bottom:1.25rem">
            <label style="display:block;font-size:0.9rem;color:#e2e8f0;margin-bottom:0.4rem;font-weight:600">Your Name</label>
            <input type="text" name="name" required style="width:100%;padding:0.75rem 1rem;border-radius:0.5rem;border:1px solid #2a3a4e;background:#0a0f1a;color:#e2e8f0;font-size:0.95rem" placeholder="John Smith" />
          </div>

          <div style="margin-bottom:1.25rem">
            <label style="display:block;font-size:0.9rem;color:#e2e8f0;margin-bottom:0.4rem;font-weight:600">Business Email</label>
            <input type="email" name="email" required style="width:100%;padding:0.75rem 1rem;border-radius:0.5rem;border:1px solid #2a3a4e;background:#0a0f1a;color:#e2e8f0;font-size:0.95rem" placeholder="john@mycompany.ca" />
          </div>

          <div style="margin-bottom:1.25rem">
            <label style="display:block;font-size:0.9rem;color:#e2e8f0;margin-bottom:0.4rem;font-weight:600">Phone Number</label>
            <input type="tel" name="phone" required style="width:100%;padding:0.75rem 1rem;border-radius:0.5rem;border:1px solid #2a3a4e;background:#0a0f1a;color:#e2e8f0;font-size:0.95rem" placeholder="+1 514-555-0100" />
          </div>

          <div style="margin-bottom:1.25rem">
            <label style="display:block;font-size:0.9rem;color:#e2e8f0;margin-bottom:0.4rem;font-weight:600">Company Name</label>
            <input type="text" name="company" style="width:100%;padding:0.75rem 1rem;border-radius:0.5rem;border:1px solid #2a3a4e;background:#0a0f1a;color:#e2e8f0;font-size:0.95rem" placeholder="ACME Plumbing Inc." />
          </div>

          <div style="margin-bottom:1.25rem">
            <label style="display:block;font-size:0.9rem;color:#e2e8f0;margin-bottom:0.4rem;font-weight:600">Trade / Service Type</label>
            <select name="trade" style="width:100%;padding:0.75rem 1rem;border-radius:0.5rem;border:1px solid #2a3a4e;background:#0a0f1a;color:#e2e8f0;font-size:0.95rem">
              <option value="">Select...</option>
              <option value="Plumbing">Plumbing</option>
              <option value="Electrical">Electrical</option>
              <option value="HVAC">HVAC</option>
              <option value="Roofing">Roofing</option>
              <option value="Landscaping">Landscaping</option>
              <option value="Painting">Painting</option>
              <option value="General Contracting">General Contracting</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <div style="margin-bottom:1.5rem">
            <label style="display:block;font-size:0.9rem;color:#e2e8f0;margin-bottom:0.4rem;font-weight:600">Message / Questions</label>
            <textarea name="message" rows="3" style="width:100%;padding:0.75rem 1rem;border-radius:0.5rem;border:1px solid #2a3a4e;background:#0a0f1a;color:#e2e8f0;font-size:0.95rem;font-family:inherit" placeholder="How many calls do you estimate you miss per week?"></textarea>
          </div>

          <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:1rem;font-size:1.05rem;margin-top:0.5rem;background:#22c55e">Book My Free Demo →</button>
        </form>
        <p style="text-align:center;font-size:0.8rem;color:#64748b;margin-top:1rem">Or call us directly: <strong style="color:#e2e8f0">+1 (514) 555-XXXX</strong> | <strong style="color:#e2e8f0">ayoub@partenairecroissance.com</strong></p>
      </div>
    </div>
  </section>
</BaseLayout>
